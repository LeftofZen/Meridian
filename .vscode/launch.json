{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Meridian",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\build\\vs2026-debug\\Debug\\Meridian.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}\\build\\vs2026-debug\\Debug",
      "environment": [
        {
          "name": "PATH",
          "value": "${workspaceFolder}\\build\\vs2026-debug\\vcpkg_installed\\x64-windows\\debug\\bin\\Debug;${workspaceFolder}\\build\\vs2026-debug\\vcpkg_installed\\x64-windows\\debug\\bin;${workspaceFolder}\\build\\vs2026-debug\\vcpkg_installed\\x64-windows\\bin;${env:PATH}"
        }
      ],
      "console": "internalConsole",
      "internalConsoleOptions": "neverOpen",
      "preLaunchTask": "Build Meridian (VS 2026)"
    },
    {
      "name": "Run Meridian (No Build)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\build\\vs2026-debug\\Debug\\Meridian.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}\\build\\vs2026-debug\\Debug",
      "environment": [
        {
          "name": "PATH",
          "value": "${workspaceFolder}\\build\\vs2026-debug\\vcpkg_installed\\x64-windows\\debug\\bin\\Debug;${workspaceFolder}\\build\\vs2026-debug\\vcpkg_installed\\x64-windows\\debug\\bin;${workspaceFolder}\\build\\vs2026-debug\\vcpkg_installed\\x64-windows\\bin;${env:PATH}"
        }
      ],
      "console": "internalConsole",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Open Tracy Profiler",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${input:tracyProfilerPath}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "console": "internalConsole",
      "internalConsoleOptions": "neverOpen",
      "noDebug": true
    }
  ],
  "compounds": [
    {
      "name": "Run Meridian + Tracy",
      "configurations": ["Open Tracy Profiler", "Run Meridian (No Build)"],
      "preLaunchTask": "Build Meridian (VS 2026)",
      "stopAll": true
    }
  ],
  "inputs": [
    {
      "id": "tracyProfilerPath",
      "type": "promptString",
      "description": "Path to the Tracy viewer executable",
      "default": "${workspaceFolder}\\build\\vs2026-debug\\vcpkg_installed\\x64-windows\\tools\\tracy\\tracy-profiler.exe"
    }
  ]
}
