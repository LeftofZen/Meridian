{
  "name": "meridian",
  "version-string": "0.1.0",
  "description": "A next-gen game engine using SDL3 and Vulkan",
  "dependencies": [
    {
      "name": "sdl3",
      "features": ["vulkan"]
    },
    "joltphysics",
    "entt",
    "gamenetworkingsockets",
    "openvdb",
    "lmdb",
    "sqlitecpp",
    "steam-audio",
    "glm",
    "spdlog",
    "flatbuffers",
    "zstd",
    {
      "name": "imgui",
      "features": ["vulkan-binding", "sdl3-binding"]
    },
    "lua",
    "sol2",
    "recastnavigation",
    "taskflow"
  ]
}
