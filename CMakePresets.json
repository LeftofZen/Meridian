{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2026-debug",
      "displayName": "Visual Studio 2026 (MSVC) Debug",
      "description": "Use the Visual Studio 2026 generator with the MSVC toolchain.",
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "binaryDir": "${sourceDir}/build/vs2026-debug",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "vscode-clang-debug",
      "displayName": "VS Code Clang Debug",
      "description": "Use clang-cl from VS Code. Requires clang-cl and the MSVC/Windows SDK build environment to be available.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/vscode-clang-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2026-debug",
      "displayName": "Visual Studio 2026 (MSVC) Debug",
      "configurePreset": "vs2026-debug",
      "configuration": "Debug"
    },
    {
      "name": "vscode-clang-debug",
      "displayName": "VS Code Clang Debug",
      "configurePreset": "vscode-clang-debug"
    }
  ]
}
