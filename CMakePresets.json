{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 29,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2026-debug",
      "displayName": "VS 2026 Debug",
      "description": "Configure Meridian with Ninja, MSVC, and vcpkg from VCPKG_ROOT.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2026-debug",
      "displayName": "VS 2026 Debug",
      "configurePreset": "vs2026-debug"
    }
  ]
}